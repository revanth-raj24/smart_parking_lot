[Unit]
Description=Smart Parking FastAPI Backend
After=network.target mysql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/var/www/smart-parking/backend
Environment="PATH=/var/www/smart-parking/backend/venv/bin"
ExecStart=/var/www/smart-parking/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
