# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
venv/
env/
.venv/

# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
**/node_modules/
**/dist/
**/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Environment & secrets (NEVER commit these) ────────────────────────────────
.env
.env.*
!.env.example        # keep the example template
**/.env
**/.env.*
!**/.env.example

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite3

# ── Captured images (large binary runtime files) ─────────────────────────────
backend/captured_images/
backend/catured-images/

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── PM2 ───────────────────────────────────────────────────────────────────────
.pm2/

# ── SSL / certificates ────────────────────────────────────────────────────────
*.pem
*.key
*.crt
*.p12

# ── Test & coverage ───────────────────────────────────────────────────────────
coverage/
.coverage
htmlcov/
.pytest_cache/
.cache/

# ── Alembic auto-generated (keep migrations, ignore pyc) ─────────────────────
backend/alembic/__pycache__/

# ── Claude Code session files ────────────────────────────────────────────────
.claude/
Claude/
