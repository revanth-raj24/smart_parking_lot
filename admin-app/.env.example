# Admin App — Environment Variables
#
# Development: Vite proxies /api → http://localhost:8000 automatically.
#              No environment variables are required for local development.
#
# Production:  Nginx serves this app as a static build and proxies /api to
#              the FastAPI backend. No runtime env vars are needed either.

# URL of the user-facing app (shown as a link in the admin panel)
VITE_USER_APP_URL=https://yourdomain.com
