# ── Database ──────────────────────────────────────────────────────────────────
# Format: sqlite:///./path/to/database.db (relative path from backend folder)
DATABASE_URL=sqlite:///./smart_parking.db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── OCR (OpenRouter) ──────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai  — uses google/gemini-2.5-flash-lite
# The openai package is used as the HTTP client (OpenRouter is OpenAI-compatible)
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_KEY_HERE

# ── ESP32 Device IPs ─────────────────────────────────────────────────────────
# NOT configured here. Devices self-register on every boot:
#   POST /api/devices/register  {"device_id":"entry","current_ip":"<dhcp>","device_type":"entry_cam"}
# Backend resolves IPs from the `devices` DB table — no static configuration needed.

# ── Image storage ─────────────────────────────────────────────────────────────
# Directory where entry/exit JPEG captures are saved
# Development:  captured_images   (relative, created automatically)
# Production:   /var/www/smart-parking/captured_images
CAPTURED_IMAGES_DIR=captured_images

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── CORS origins ─────────────────────────────────────────────────────────────
# Development defaults — update to your real domain in production
USER_APP_ORIGIN=http://31.97.231.29:6640
ADMIN_APP_ORIGIN=http://31.97.231.29:6641

# ── Database seed (used by: python -m app.db.seed) ───────────────────────────
# Change these before running the seed script in production
ADMIN_SEED_EMAIL=admin@smartpark.com
ADMIN_SEED_PASSWORD=Admin@24smartpark
